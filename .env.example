# copy to .env
PORT=3000
# free key from https://rawg.io/apidocs — game cover search works without it disabled
RAWG_API_KEY=
# Supabase project (Settings -> API in your Supabase dashboard). Required — run
# supabase/schema.sql once in the SQL Editor before first boot.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
